<?xml version="1.0"?>
<ruleset name="SubnetCalculator">
    <description>PSR-12 with test-file relaxations.</description>

    <rule ref="PSR12"/>

    <!-- Test files: PHPUnit convention uses underscores in method names
         and top-level classes without a namespace. -->
    <rule ref="PSR1.Classes.ClassDeclaration">
        <exclude-pattern>testing/unit/*</exclude-pattern>
    </rule>
    <rule ref="PSR2.Methods.MethodDeclaration">
        <exclude-pattern>testing/unit/*</exclude-pattern>
    </rule>
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>testing/unit/*</exclude-pattern>
    </rule>
    <rule ref="Squiz.Classes.ValidClassName">
        <exclude-pattern>testing/unit/*</exclude-pattern>
    </rule>
</ruleset>
