FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        wget \
        ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN useradd -r -u 1001 -m -s /bin/bash pwuser

WORKDIR /app

COPY testing/requirements.txt /app/testing/requirements.txt
# Install Python packages and system-level Playwright deps as root
RUN pip install --no-cache-dir -r testing/requirements.txt \
    && playwright install-deps chromium

# Install browser binaries as pwuser so they land in /home/pwuser/.cache
USER pwuser
RUN playwright install chromium

USER root
COPY --chown=pwuser:pwuser . /app/

USER pwuser
