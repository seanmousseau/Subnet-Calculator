parameters:
    level: 9
    phpVersion: 80100
    # Analyse only the entry point so PHPStan follows the require chain in the
    # same order the app uses, giving it full context for every global variable.
    paths:
        - Subnet-Calculator/index.php
        - Subnet-Calculator/includes/functions-ipv4.php
        - Subnet-Calculator/includes/functions-ipv6.php
        - Subnet-Calculator/includes/functions-split.php
        - Subnet-Calculator/includes/functions-util.php
        - Subnet-Calculator/includes/functions-vlsm.php
        - Subnet-Calculator/includes/functions-supernet.php
        - Subnet-Calculator/includes/functions-ula.php
        - Subnet-Calculator/includes/functions-session.php
        - Subnet-Calculator/includes/functions-resolve.php
        - Subnet-Calculator/includes/functions-range.php
        - Subnet-Calculator/includes/functions-tree.php
        - Subnet-Calculator/api/v1/helpers.php
        - Subnet-Calculator/api/v1/index.php
        - Subnet-Calculator/api/v1/handlers/ipv4.php
        - Subnet-Calculator/api/v1/handlers/ipv6.php
        - Subnet-Calculator/api/v1/handlers/vlsm.php
        - Subnet-Calculator/api/v1/handlers/overlap.php
        - Subnet-Calculator/api/v1/handlers/split.php
        - Subnet-Calculator/api/v1/handlers/supernet.php
        - Subnet-Calculator/api/v1/handlers/ula.php
        - Subnet-Calculator/api/v1/handlers/bulk.php
        - Subnet-Calculator/api/v1/handlers/rdns.php
        - Subnet-Calculator/api/v1/handlers/sessions.php
        - Subnet-Calculator/api/v1/handlers/range.php
        - Subnet-Calculator/api/v1/handlers/tree.php
        - Subnet-Calculator/api/v1/handlers/changelog.php
    # config.php is gitignored (user override) — skip if absent
    excludePaths:
        - Subnet-Calculator/config.php (?)
    ignoreErrors:
        # PHPStan does not propagate global variables through PHP's require
        # chain. These 4 variables are always set by includes/config.php
        # (required unconditionally at index.php:4), but PHPStan can't see
        # that because it doesn't track globals across included files.
        - message: '#Variable \$(frame_ancestors|form_protection|turnstile_site_key|turnstile_secret_key|hcaptcha_site_key|hcaptcha_secret_key|recaptcha_enterprise_site_key|recaptcha_enterprise_api_key|recaptcha_enterprise_project_id|recaptcha_score_threshold) might not be defined\.#'
          path: Subnet-Calculator/index.php

        # The config-default-vs-sanitise checks in includes/config.php look
        # like always-true/false to PHPStan because it sees the defaults set
        # just above. The optional user config.php override (required between
        # defaults and sanitisation) can change those values at runtime.
        - '#^Call to function in_array\(\) with arguments .+ will always evaluate to (true|false)\.$#'
        - '#^Strict comparison using === between .+ will always evaluate to (true|false)\.$#'

        # api/v1/index.php uses $api_request_log from config.php (required at the
        # top of index.php) — PHPStan cannot trace globals across require chains.
        - message: '#Variable \$api_request_log might not be defined\.#'
          path: Subnet-Calculator/api/v1/index.php

        # API handlers are required by api/v1/index.php after helpers.php sets
        # up globals ($method, $uri) and after config.php sets $split_max_subnets,
        # $session_enabled, $session_db_path, $session_ttl_days. PHPStan analyses
        # handlers in isolation and cannot see those bootstrap globals.
        - message: '#Variable \$(method|uri|split_max_subnets|session_enabled|session_db_path|session_ttl_days) might not be defined\.#'
          paths:
            - Subnet-Calculator/api/v1/handlers/

        # api_body() returns array<string, mixed>; values from JSON are mixed by
        # definition. Handlers cast to string/int at the boundary — this is the
        # intended pattern for accepting user-supplied JSON fields.
        - message: '#^Cannot cast mixed to (string|int)\.$#'
          paths:
            - Subnet-Calculator/api/v1/handlers/

        # Handlers pass validated body fields (mixed from JSON) to functions
        # expecting string. Values have been validated above the call sites.
        - message: '#Parameter .+ of function (ltrim|explode|cidrs_overlap|cidrs_overlap6|build_subnet_tree) expects .+, (mixed|array<mixed, mixed>) given#'
          paths:
            - Subnet-Calculator/api/v1/handlers/

        # rdns.php: inet_pton/gethostbyaddr return string|false; validated above.
        - message: '#Parameter .+ of function (explode|str_replace) expects .+, string\|false given#'
          path: Subnet-Calculator/api/v1/handlers/rdns.php
